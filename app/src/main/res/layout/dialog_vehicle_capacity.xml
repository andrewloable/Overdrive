<?xml version="1.0" encoding="utf-8"?>
<!--
  Vehicle capacity / model picker dialog.

  Two surfaces:
    - Summary block (read-only): current capacity, SOH, effective kWh, model,
      last calibration. Each line shows itself only when its data is real.
    - Editable controls: M3 outlined capacity input + M3 ExposedDropdownMenu
      for model selection. The dropdown expands like a Material menu, not a
      legacy Spinner.
-->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="false">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <!-- Summary block. Each TextView is GONE by default and gets populated +
             revealed by the fragment when its source data is meaningful. -->
        <TextView
            android:id="@+id/vehicleSummaryCapacity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="?attr/colorOnSurface"
            android:visibility="gone" />

        <TextView
            android:id="@+id/vehicleSummarySoh"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="?attr/colorOnSurface"
            android:visibility="gone" />

        <TextView
            android:id="@+id/vehicleSummaryEffective"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:visibility="gone" />

        <TextView
            android:id="@+id/vehicleSummaryModel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textAppearance="@style/TextAppearance.Material3.BodyMedium"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:visibility="gone" />

        <TextView
            android:id="@+id/vehicleSummaryCalibration"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textAppearance="@style/TextAppearance.Material3.BodySmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:visibility="gone" />

        <View
            android:id="@+id/vehicleSummaryDivider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="20dp"
            android:background="?attr/colorOutlineVariant"
            android:visibility="gone" />

        <!-- Model dropdown — M3 ExposedDropdownMenu. The MaterialAutoCompleteTextView
             is non-editable so users tap the field and pick from the menu rather
             than typing. -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/vehicleModelLayout"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/vehicle_dialog_model_label">

            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                android:id="@+id/vehicleModelDropdown"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Capacity input — M3 outlined text field with kWh suffix. -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/vehicle_dialog_capacity_label"
            app:helperText="@string/vehicle_dialog_capacity_helper"
            app:helperTextEnabled="true"
            app:suffixText="@string/vehicle_dialog_capacity_suffix">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/vehicleCapacityInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:imeOptions="actionDone"
                android:inputType="numberDecimal"
                android:maxLines="1"
                android:textAppearance="@style/TextAppearance.Material3.BodyLarge" />
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
