<?xml version="1.0" encoding="utf-8"?>
<!--
  Material Symbols Rounded: notifications (24px, weight 400, fill 0).

  Uses the canonical 960x960 viewport with y flipped to keep the path
  coordinates in their original (unscaled) form. Earlier revision wrapped
  the path in a <group> with scaleX/scaleY=0.025 + translateY=24 so the
  viewBox could stay 24x24, but on Chrome 58 / Android 7.1 head-units the
  inner-group transform path was occasionally clipped on the trailing edge,
  making the bell + clapper look cropped on the right. Going straight to
  the original viewport renders the icon with no transform clipping.
-->
