<?xml version="1.0" encoding="utf-8"?>
<!--
  3dp gradient stripe rendered under the MaterialToolbar.

  Anchors the Overdrive identity: brand primary (M3 colorPrimary) ramps to
  tertiary (M3 colorTertiary, sky-blue accent for vehicle/data viz) across
  the screen width. Light/dark aware via theme attrs — no hardcoded hex.

  Mirrored on the web side via app-shell.css's `.sidebar::before` and
  `.app-bar::after` rules so the user perceives a single visual identity
  across the native shell and the WebView pages.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="0"
        android:startColor="?attr/colorPrimary"
        android:endColor="?attr/colorTertiary"
        android:type="linear" />
</shape>
