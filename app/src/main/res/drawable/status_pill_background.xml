<?xml version="1.0" encoding="utf-8"?>
<!--
  Toolbar status pill background. Tonal surface with a subtle outline so the
  pill reads as a touch target without competing with the toolbar background.
  Pressed state lifts to a brighter surface tier.
-->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="?attr/colorSurfaceContainerHigh" />
            <stroke android:width="1dp" android:color="?attr/colorOutlineVariant" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="?attr/colorSurfaceContainerLow" />
            <stroke android:width="1dp" android:color="?attr/colorOutlineVariant" />
            <corners android:radius="20dp" />
        </shape>
    </item>
</selector>
