<?xml version="1.0" encoding="utf-8"?>
<!--
  Floating status overlay pill background.

  Colors come from @color/overlay_pill_* so the pill follows the app's
  day/night theme — the values-night variants flip both fill and stroke.
  Previously hard-coded to dark-only (#CC16161A / #3300D4AA), which made
  the pill read as a black blob over a light-themed launcher.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/overlay_pill_background" />
    <corners android:radius="20dp" />
    <stroke
        android:width="1dp"
        android:color="@color/overlay_pill_stroke" />
</shape>
